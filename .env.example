ANTHROPIC_API_KEY=sk-ant-...

# Higgsfield Cloud (Flux/Soul imagenes + Seedance/DoP video) — requiere balance > 0 en cloud.higgsfield.ai
HF_CLOUD_KEY=...
HF_CLOUD_SECRET=...

# Motor de voz a usar cuando hay más de uno configurado: "chatterbox" (RECOMENDADO
# — pago por caracter, ~$0.016/reel, sin riesgo de suscripción, usa
# pipeline/assets/guillermo_ref.wav ya en el repo) o vacío/otro valor para
# usar ElevenLabs si está configurado. Sin ninguna de las dos, cae a XTTS
# gratis y de ahí a Edge-TTS — nunca tumba un reel.
VOICE_ENGINE=chatterbox

# ElevenLabs — voz clonada real de Guillermo (voice_id y69I2R3lXBl3VNuimqcD).
# Suscripción mensual — si el saldo se agota (como pasó el 2026-07-06) o las
# credenciales fallan, cae automáticamente a XTTS-v2/Edge-TTS. Solo se usa si
# VOICE_ENGINE != "chatterbox".
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=y69I2R3lXBl3VNuimqcD

# fal.ai — UNA sola key para tres cosas: (1) motor de video Seedance 1.5 Pro
# (default, ~$0.10-0.15/clip, mejor y más barato que Wan), con Wan 480p como
# respaldo si falla; (2) frame FLUX-pro para animar; (3) Chatterbox (voz de
# Guillermo, ~$0.016/reel, ver ELEVENLABS/VOICE_ENGINE abajo). Sacar en
# fal.ai/dashboard/keys — pago por uso, sin suscripción mensual.
FAL_KEY=...
# "seedance" (default, recomendado) o "wan" para volver al motor viejo.
FAL_VIDEO_ENGINE=seedance

# Google Veo 3.1 (Gemini API) — motor de video de pago PRIORITARIO, mejor
# calidad/movimiento real que Wan y audio nativo incluido, a costo similar o
# menor (~$0.20/clip de 4s en Lite 720p). Se necesitan AMBAS variables para
# activarse — con solo GEMINI_API_KEY puesta pero USE_VEO=false no gasta nada.
# Sacar la key en aistudio.google.com (misma cuenta que ya tienes conectada a
# Composio) — para producción 24/7 se llama la API REST directo, no Composio.
GEMINI_API_KEY=...
USE_VEO=false
VEO_MODEL=veo-3.1-lite-generate-preview

# Tope de clips pagados por reel (Veo o fal.ai, lo que esté activo) — controla
# el gasto máximo. Con Veo Lite a $0.20/clip, 7 clips ≈ $1.40/reel de video.
FAL_MAX_PAID_CLIPS=7

PORT=3000
