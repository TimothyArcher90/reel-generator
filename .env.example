ANTHROPIC_API_KEY=sk-ant-...

# Higgsfield Cloud (Flux/Soul imagenes + Seedance/DoP video) — requiere balance > 0 en cloud.higgsfield.ai
HF_CLOUD_KEY=...
HF_CLOUD_SECRET=...

# ElevenLabs — voz clonada real de Guillermo (voice_id y69I2R3lXBl3VNuimqcD).
# Si faltan (o el saldo/cuenta falla), el pipeline cae automáticamente a
# XTTS-v2 gratis y de ahí a Edge-TTS genérico — nunca tumba un reel.
# Verificar saldo real en elevenlabs.io ANTES de esperar que esto funcione:
# el incidente del 2026-07-06 fue justamente saldo agotado, no un bug de código.
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=y69I2R3lXBl3VNuimqcD

# fal.ai — motor de video de pago de respaldo (frame FLUX-pro + animación Wan
# 480p, ~$0.24-0.28/clip). Se usa solo si Veo no está configurado o falla.
FAL_KEY=...

# Google Veo 3.1 (Gemini API) — motor de video de pago PRIORITARIO, mejor
# calidad/movimiento real que Wan y audio nativo incluido, a costo similar o
# menor (~$0.20/clip de 4s en Lite 720p). Se necesitan AMBAS variables para
# activarse — con solo GEMINI_API_KEY puesta pero USE_VEO=false no gasta nada.
# Sacar la key en aistudio.google.com (misma cuenta que ya tienes conectada a
# Composio) — para producción 24/7 se llama la API REST directo, no Composio.
GEMINI_API_KEY=...
USE_VEO=false
VEO_MODEL=veo-3.1-lite-generate-preview

# Tope de clips pagados por reel (Veo o fal.ai, lo que esté activo) — controla
# el gasto máximo. Con Veo Lite a $0.20/clip, 7 clips ≈ $1.40/reel de video.
FAL_MAX_PAID_CLIPS=7

PORT=3000
